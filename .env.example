# Copy to .env.local and fill in values. Never commit real keys.

MISTRAL_API_KEY=
YOUTUBE_API_KEY=

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only (optional; not required for MVP Realtime)
SUPABASE_SECRET_KEY=

NEXT_PUBLIC_APP_URL=https://justduo.vercel.app

# Optional model override (default tries several free-tier models)
# MISTRAL_MODEL=mistral-small-latest
