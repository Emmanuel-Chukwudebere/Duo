# Copy to .env.local and fill in values. Never commit real keys.

MISTRAL_API_KEY=
YOUTUBE_API_KEY=

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only (optional; not required for MVP Realtime)
SUPABASE_SECRET_KEY=

NEXT_PUBLIC_APP_URL=https://justduo.vercel.app

# Optional model override (default tries several free-tier models)
# MISTRAL_MODEL=mistral-small-latest

# --- WebRTC TURN relay (REQUIRED for cross-device / cross-network calls) ---
# Without a working TURN relay, partners on different networks get stuck at
# "connecting to media". STUN alone only connects peers on the same network.
#
# Recommended: Cloudflare Realtime TURN (free tier ~1TB/mo). Create a TURN key at
# dash.cloudflare.com → Realtime → TURN. The app mints short-lived creds server-side.
CLOUDFLARE_TURN_TOKEN_ID=
CLOUDFLARE_TURN_API_TOKEN=
#
# OR any other provider (Twilio, metered.ca paid, self-hosted coturn) via static creds:
# TURN_URLS=turn:your.turn.server:3478,turns:your.turn.server:5349
# TURN_USERNAME=
# TURN_CREDENTIAL=
